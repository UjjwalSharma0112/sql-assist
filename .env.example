# --- Frontend Configuration ---
# Public URL of the backend API (without trailing slash, e.g. http://localhost:8000/api/v1 or https://api.yourdomain.com/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Backend Configuration ---
# Secret key used for signing JWT tokens. Change this to a secure random string in production.
SECRET_KEY=your-super-secret-jwt-key

# Database URL. Defaults to SQLite for local development.
DATABASE_URL=sqlite:///data/users.db

# API Key for Google Gemini (needed for NL2SQL query generation)
GEMINI_API_KEY=your-gemini-api-key-here

# Allowed origins for CORS (comma-separated). Leave empty to use defaults (localhost).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
